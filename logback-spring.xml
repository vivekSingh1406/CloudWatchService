<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="AWS_REGION" source="aws.region" defaultValue="ap-south-1"/>
    <springProperty scope="context" name="CW_LOG_GROUP" source="aws.cloudwatch.log-group" defaultValue="sprint-boot-application"/>
    <springProperty scope="context" name="CW_LOG_STREAM" source="aws.cloudwatch.log-stream" defaultValue="app-log-stream"/>

    <!-- Console appender (local dev) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- AWS CloudWatch Logs appender -->
    <appender name="CLOUD_WATCH" class="ca.pjer.logback.AwsLogsAppender">

        <!-- CloudWatch Log Group name (must already exist or set createIfNeeded=true) -->
        <logGroupName>${CW_LOG_GROUP}</logGroupName>

        <!-- Log Stream name; use ${instanceId} in EC2 for per-instance streams -->
        <logStreamName>${CW_LOG_STREAM}</logStreamName>

        <!-- AWS region -->
        <logRegion>${AWS_REGION}</logRegion>

        <!-- Flush every 2 seconds even if buffer isn't full -->
        <maxFlushTimeMillis>2000</maxFlushTimeMillis>

        <!-- Max events per batch (CloudWatch limit is 10,000) -->
        <maxBatchLogEvents>128</maxBatchLogEvents>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>

    </appender>

    <!-- Async wrapper — prevents logging from blocking request threads -->
    <appender name="ASYNC_CW" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CLOUD_WATCH"/>
        <neverBlock>true</neverBlock>
        <queueSize>512</queueSize>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_CW"/>
    </root>

</configuration>